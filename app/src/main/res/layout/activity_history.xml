<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="8dp"
    android:gravity="center_vertical">
    <TextView
        android:id="@+id/tvLocationName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textSize="16sp" />
    <Button android:id="@+id/btnUp" android:layout_width="50dp" android:layout_height="wrap_content" android:text="↑" />
    <Button android:id="@+id/btnDown" android:layout_width="50dp" android:layout_height="wrap_content" android:text="↓" />
    <Button android:id="@+id/btnDelete" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="削除" android:backgroundTint="#F44336" />
</LinearLayout>
