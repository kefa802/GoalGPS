<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="8dp"
    android:background="#FFFFFF"
    android:gravity="center_vertical">

    <TextView
        android:id="@+id/tvLogName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1.5"
        android:textSize="14sp"
        android:textColor="#333333" />

    <TextView
        android:id="@+id/tvLogInTime"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:gravity="center"
        android:padding="4dp"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tvLogOutTime"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:gravity="center"
        android:padding="4dp"
        android:textSize="14sp" />

    <Button android:id="@+id/btnRowUp" android:layout_width="35dp" android:layout_height="40dp" android:text="↑" android:textSize="10sp" android:padding="0dp" />
    <Button android:id="@+id/btnRowDown" android:layout_width="35dp" android:layout_height="40dp" android:text="↓" android:textSize="10sp" android:padding="0dp" />
    <Button android:id="@+id/btnRowDel" android:layout_width="35dp" android:layout_height="40dp" android:text="削" android:textSize="10sp" android:padding="0dp" android:backgroundTint="#FF5252" />
</LinearLayout>
